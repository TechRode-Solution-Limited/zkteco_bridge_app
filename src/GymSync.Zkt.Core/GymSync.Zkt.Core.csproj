<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latest</LangVersion>
    <RootNamespace>GymSync.Zkt.Core</RootNamespace>
    <AssemblyName>GymSync.Zkt.Core</AssemblyName>
    <!-- Late-bound COM access to zkemkeeper.CZKEM via Type.GetTypeFromProgID.
         No TLB import required at build time; the ZKTeco SDK (zkemkeeper.dll)
         must be registered on the runtime host: regsvr32 zkemkeeper.dll -->
  </PropertyGroup>

</Project>
